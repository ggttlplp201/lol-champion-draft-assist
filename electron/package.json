{
  "name": "draft-advisor",
  "version": "1.2.0",
  "description": "League of Legends Draft Advisor overlay",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac dmg",
    "build-win": "electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.lol.draftadvisor",
    "productName": "Draft Advisor",
    "directories": { "output": "../dist" },
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.games"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true
    },
    "extraResources": [
      {
        "from": "../dist/DraftAdvisorServer",
        "to": "server"
      }
    ]
  }
}
